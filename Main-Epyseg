import os
import subprocess
import tifffile as tif
import numpy as np
import sys

env = os.environ.copy()
env.pop("MPLBACKEND", None)

#Before starting, make sure you made a specific directory in Documents where you will put the base image
path = "/Users/name/Documents/directory_name/"
#Use a duplicate of your image from microscope, that you will save in the directory without modifying the name. It will make it a .tif file, that we will refer here as "base image"
#This will automatically detect the base image you put in the directory, based on its first 2 characters
for root, dirs, files in os.walk(path):
    for i in files:
        #Enter after "i[0:2]==" the two first characters of your file's name
        #"i[-4:]==" ensures the file is a .tif file
        if i[0:2]=="yw" and i[-4:]==".tif":
            file_name= i[0:-4]
            print("Using following file :" )
            print(i)
            break

chinmo_yn = "n" # "y" if you want to detect protein of interest and "n" if you dont
chinmo_channel = 2 #If you entered "y" in chinmo_yn, you must put here the channel of detection of your spots. Default is 2.
seg = "y" #If you want to segment your cells. If "n", cells wont be segmented but type file (Detection of protein indicating type in the cells) will be produced anyway.
detect = "y" #If you want to detect spots
             #If spots are already detected and stored in a tif file, you will still have to perform Connected Components Analysis and Intensity measurements 2D/3D in FIJI (see below) 

print("Segmentation part")
#Segmentation script lauching. It needs special environnement called "segment" to work. Descriptions of the necessary environnements are in the README.
result = subprocess.run(
     f'conda run -n segment python segmentation_cellpose-Epyseg.py "{file_name}" "{seg}" "{path}"',
     shell=True,
     env=env,
     capture_output=True,
     text=True)
print(result.stdout)
print(result.stderr)

if detect=="y":
    print("Detection part")
    #Spot Detection script lauching. It needs "chinmospots" environnement.
    result = subprocess.run(
        f'conda run -n chinmospots python spot_segmentation.py "{file_name}" "{path}"',
        shell=True,
        env=env,
        capture_output=True,
        text=True
        )

    print(result.stderr)
    print("Done")

#This will produce a file that will allow you to see clearly what points have been detected in the cells
#Only the points with more than 50% chance to be a real spot are kept (see below)
detected = tif.imread(path + "detected_" + file_name + ".tif")
miranda = tif.imread(path + "shrinked_" + file_name + ".tif")
miranda = miranda > 0 
miranda = miranda.astype(np.uint16)
merge = detected * miranda
tif.imwrite(path + "merge_" + file_name + ".tif", merge)

#Thresholding of points with high probability to be points (here, 0.5 means we keep only points with more than 50% chance to be points, according to the detection file)
binary = detected>0.5
#Thresholded image is made binary, so that it is usable in FIJI, and then saved in the directory as "chinmo_threshold_" followed by the name of the base file.
binary = binary.astype(np.uint16) * 255
tif.imwrite(path + "chinmo_threshold_" + file_name + ".tif", binary)

#This will tell you when its finished so you get back on the code and do things
import winsound
winsound.Beep(500, 700)
winsound.Beep(500, 700)

#You will then have to perform CCA with FIJI MorphoLibJ plugin on chinmo_threshold_ file. You just have to open it with FIJI and perform CCA directly, without changing any parameter.
#You will then have to save it as it comes, without changing anything in the name.
#This file will contain detected points with one specific color ("label") added to each one of them.
print("Perform MorpholibJ Connected Components Analysis on chinmo_threshold_ then save it")

#This will wait for you to perform CCA and will detect the new file by the "-lbl" at its name's end
while not os.path.isfile(path + "chinmo_threshold_" + file_name + "-lbl.tif"):
    time.sleep(10)
   
#This will produce a new file keeping only the pixels of the file we just produced that are in the cells
#It will be used to compare volume outside and inside of the cell for every point later
labeled = tif.imread(path + "chinmo_threshold_" + file_name + "-lbl.tif")
merge_threshold = labeled * miranda
tif.imwrite(path + "merge_threshold_" + file_name + ".tif", merge_threshold)



#You will then have to perform measurements with MorpholibJ
#To do that, open your base image in FIJI, right click on it and click duplicate. Enter your spot channel alone in "channels", "duplicate stack" must be activated
#Then open merge_threshold_ file and go find morpholibj in FIJI plugins. Go in analyze and find Intensity Measurements 2D/3D. 
#Choose the duplicate of the chinmo channel from the base image as input (might be the same name as base image but with a "-1" at the end.
#Choose merge_threshold_ file as labels. The only data that are important are Mean, Number of Voxels, Volume, and CenterofMass
#It will give you an array containing those values associated with labels from every point. Save it as it comes, without changing anything.
print("Perform MorpholibJ Intensity Measurements 2D/3D with a duplicate of the chinmo channel from "
      "the base stack as input and merge_threshold_ as labels")

#This will wait for you to produce the measurements file
while not os.path.isfile(path + file_name + '-1-intensity-measurements.csv'):
    time.sleep(5)

#This will ask you if you want to perform directly the analysis
proceed = input("Intensity measurements are done, proceed to data analysis ? [y]/n  ", )

#If you precised you want to measure protein of interest, this will ensure you did not forget to put the right channel
if chinmo_yn == "y": 
    chinmo_channel = input("Enter the channel of the protein of interest (0, 1, 2, 3) : ", )


if proceed == "n":
    print("If you want to continue later, do so by starting this program at the input line")

elif proceed == "y":
#This will launch the spot analysis code in the spots_analysis environnement. 
    result = subprocess.run(
        f'conda run -n spots_analysis python Spots_analysis-Epyseg.py "{file_name}" "{chinmo_yn}" "{chinmo_channel}" "{path}"',
        shell=True,
        env=env,
        capture_output=True,
        text=True
    )
    print(result.stderr)
    print(result.stdout)
    print("Done")
